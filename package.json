{
  "name": "snapgrab",
  "version": "1.1.0",
  "description": "SnapGrab - Premium Media Downloader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir",
    "release": "electron-builder --win --publish always",
    "push": "git add . && git commit -m \"update\" && git push && npm run release"
  },
  "keywords": [],
  "author": "SnapGrab",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.snapgrab.app",
    "productName": "SnapGrab",
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "public/icon.png",
      "signAndEditExecutable": false,
      "artifactName": "SnapGrab.${version}.${ext}",
      "publish": {
        "provider": "github",
        "owner": "shaswatxd",
        "repo": "snapgrab-downloader",
        "releaseType": "release"
      }
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "artifactName": "SnapGrab.Setup.exe"
    },
    "portable": {
      "artifactName": "SnapGrab.Portable.exe"
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*"
    ]
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
