{
  "name": "snapgrab",
  "version": "1.0.0",
  "description": "SnapGrab - Premium Media Downloader",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "dev": "electron .",
    "build": "electron-builder --win",
    "pack": "electron-builder --dir"
  },
  "keywords": [],
  "author": "SnapGrab",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "electron": "^41.2.1",
    "electron-builder": "^26.8.1"
  },
  "build": {
    "appId": "com.snapgrab.app",
    "productName": "SnapGrab",
    "win": {
      "target": ["nsis", "portable"],
      "icon": "public/icon.png",
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "files": [
      "main.js",
      "preload.js",
      "public/**/*"
    ],
    "extraResources": [
      {
        "from": "bin/",
        "to": "bin/",
        "filter": [
          "**/*"
        ]
      }
    ]
  }
}
